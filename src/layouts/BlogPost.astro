---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { MAIN_SITE_URL, CALENDLY_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} pubDate={pubDate} type="article" />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.backlink-cta {
				margin-top: 3rem;
				padding: 2rem;
				border-radius: 12px;
				background: oklch(96.5% 0.004 264);
				border: 1px solid oklch(89% 0.005 264);
				text-align: center;
			}
			.backlink-cta h3 {
				font-family: 'Barlow Condensed', sans-serif;
				font-size: 1.5rem;
				font-weight: 700;
				margin-bottom: 0.5rem;
				color: oklch(16% 0.008 264);
			}
			.backlink-cta p {
				font-size: 0.9375rem;
				color: oklch(40% 0.006 264);
				margin-bottom: 1.25rem;
				line-height: 1.65;
			}
			.backlink-cta a {
				display: inline-block;
				padding: 0.75rem 1.5rem;
				background: oklch(50.5% 0.20 264);
				color: oklch(99% 0.003 264);
				border-radius: 6px;
				font-weight: 600;
				font-size: 0.9375rem;
				text-decoration: none;
				transition: background 0.18s ease;
			}
			.backlink-cta a:hover {
				background: oklch(45.5% 0.20 264);
			}
			.author-box {
				margin-top: 2rem;
				padding-top: 1.5rem;
				border-top: 1px solid oklch(89% 0.005 264);
				font-size: 0.875rem;
				color: oklch(40% 0.006 264);
				line-height: 1.65;
			}
			.author-box strong {
				color: oklch(16% 0.008 264);
			}
			.author-box a {
				color: oklch(50.5% 0.20 264);
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />

					<div class="backlink-cta">
						<h3>Ready to automate your lead pipeline?</h3>
						<p>
							RNG Media builds AI-powered lead systems and branded content for
							real estate agents and attorneys. See how it works at
							<a href={MAIN_SITE_URL}>rngmedia.co</a>.
						</p>
						<a href={CALENDLY_URL} target="_blank" rel="noopener noreferrer">
							Book a Free Strategy Call
						</a>
					</div>

					<div class="author-box">
						<strong>Mitch Carter</strong> is the founder of
						<a href={MAIN_SITE_URL}>RNG Media</a>, an AI automation and content
						agency serving real estate agents and attorneys across the Carolinas.
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
